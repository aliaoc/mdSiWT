!     Energy tables for the TERSOFF potential.
!     Parameters obtained from 
!     "J. Tersoff, Modelling solid-state chemistry: Interatomic potentials 
!     for multicomponent systems, Phys. Rev. B 39, 5566 (1989)".
!     Avinash M. Dongare and Leonid V. Zhigilei [July 2003]
!
!     Copyright (c) 2000-2004 Computational Materials Group, UVa
!     Leonid Zhigilei, http://www.faculty.virginia.edu/CompMat/
!***************************************************************

      SUBROUTINE EF1_TFM(KTEF,KE1,KE2)
        INCLUDE 'common.h'

!       KTEF - type of the potential
!       KE1, KE2 - elements from the list Element(N)
!       Units: XT in Angs, UT in eV, FT in eV/Angs, mass in amu

        INTEGER I
        REAL *8 XT,A,B,TL1,TM1,RC,SC,DX,ANG
        
        CHARACTER*2, DIMENSION(2), PARAMETER:: Element = (/'Si','Ge'/)
        
        REAL*8, DIMENSION(2), PARAMETER:: mass=   &   ! M M M
             (/ 28.0855D+00, 72.64D+00/)
        REAL*8, DIMENSION(2), PARAMETER:: TSF_A=   &  ! A A A
             (/1830.8D+00, 1769.0D+00/)
        REAL*8, DIMENSION(2), PARAMETER:: TSF_B=   &  ! B B B 
             (/471.18D+00, 419.23D+00 /)

!       Constants in /A
        REAL*8, DIMENSION(2), PARAMETER:: TSF_L1=   &  ! L1 L1 L1
             (/2.4799D+00, 2.4451D+00/)  
        REAL*8, DIMENSION(2), PARAMETER:: TSF_M1=   &  ! L2 L2 L2
             (/1.7322D+00, 1.7047D+00/)
        REAL*8, DIMENSION(3), PARAMETER:: TSF_KSI=   &  ! kappa link
             (/1.000D+00, 1.000D+00, 1.00061D+00/)
        
!       Parameters: 
        REAL*8, DIMENSION(2), PARAMETER:: TSF_WIJ=   &    
             (/ 1.0D+00, 1.0D+00 /)
        REAL*8, DIMENSION(2), PARAMETER:: TSF_Bet=   & ! beta beta beta   
             (/ 1.1D-06, 9.0166D-07 /)
        REAL*8, DIMENSION(2), PARAMETER:: TSF_C=   &  ! c c c  
             (/ 1.0039D+05, 1.0643D+05 /)
        REAL*8, DIMENSION(2), PARAMETER:: TSF_D=   &  ! d d d
             (/ 16.217D+00, 15.652D+00 /)
        REAL*8, DIMENSION(2), PARAMETER:: TSF_H=   &   ! h h h
             (/ -0.59826D+00, -0.43884D+00/)
        REAL*8, DIMENSION(2), PARAMETER:: TSF_N=   &   ! ETA ETA ETA
             (/ 0.78734D+00, 0.75627D+00 /)

!       Cutoff distance
!       Req + one eighth the distance between second neighbor
        REAL*8, DIMENSION(2), PARAMETER:: TSF_RC=   &   ! R1 R1 R1
             (/ 2.7D+00, 2.8D+00 /) 
!       Req + seven eighth the distance between second neighbor
        REAL*8, DIMENSION(2), PARAMETER:: TSF_SC=   &   ! R2 R2 R2
             (/ 3.0D+00, 3.1D+00 /)

        real*8 :: rcc = 6.875d0   ! cutoff in angstroem if Si and H2O are in the couple

        INTEGER, PARAMETER :: Modification = 2 !(1 - Classic, 2 - T3, 3 - MOD)
        
        Select case (Modification)
        case (1) ! Classic parametrization
           TSFA = TSF_A(KE1)
           TSFB = TSF_B(KE1)
           TSFL1 = TSF_L1(KE1)
           TSFM1 = TSF_M1(KE1)
           TFN = TSF_N(KE1)
           TFH = TSF_H(KE1)
           delSF = 1.0d0/(2.0d0*TFN)
           TSFRC = TSF_RC(KE1)
           TSFSC = TSF_SC(KE1)
           
           ATF = 1.0d0
           CC1 = ATF
           CC2 = ATF*(TSF_C(1)/TSF_D(1))**2.0d0
           CC3 = TSF_D(1)*TSF_D(1)
           CC4 = 0.0d0
           CC5 = 0.0d0
           TFMalpha = 5.1975d0
           TFMbeta = 3.0d0
           TSFBet = TSF_Bet(KE1)

        case (2) ! T3 Advanced parametrization
           TSFA = TSF_A(KE1)
           TSFB = TSF_B(KE1)
           TSFL1 = TSF_L1(KE1)
           TSFM1 = TSF_M1(KE1)
           TFN = TSF_N(KE1)
           delSF = 1.0d0/(2.0d0*TFN)
           TFH = TSF_H(KE1)
           TSFRC = TSF_RC(KE1)
           TSFSC = TSF_SC(KE1)
           
           ATF = 1.0d0
           CC1 = 0.0000010999d0
           CC2 = 42.150d0
           CC3 = 262.99d0
           CC4 = 0.0d0
           CC5 = 0.0d0
           TFMalpha = 5.1975d0
           TFMbeta = 3.0d0
           TSFBet = 1.0d0

        case (3) ! MOD Modified for amorphization
           TSFA  = 3281.5905d0
           TSFB  = 121.00047d0
           TSFL1 = 3.2300135d0
           TSFM1 = 1.3457970d0
           TFN   = 1.0d0
           delSF = 0.53298909d0/TFN
           TFH = -0.365d0
           TSFRC = 2.7d0
           TSFSC = 3.3d0

           ATF = 1.0d0
           CC1 = 0.20173476d0
           CC2 = 730418.72d0
           CC3 = 1000000.0d0
           CC4 = 1.0d0
           CC5 = 26.0d0
           TFMalpha = 2.3890327d0
           TFMbeta = 1.0d0
           TSFBet = 1.0d0

        End select
           
!        IF (mypid.eq.0) Write (17,*) 'Creating tables for ', Element(KE1),'-', &
!             Element(KE2),' Tersoff potential' 
        
        IF(KE1.EQ.KE2) Then 
           XMass(KTEF) = MASS(KE1)
           TF_C(KTEF) = TSF_C(KE1)
           TF_D(KTEF) = TSF_D(KE1)
           TF_H(KTEF) = TFH
           TF_N(KTEF) = TFN
           TF_Bet(KTEF) = TSFBet
           TL1 = TSFL1
           TM1 = TSFM1
           RC =TSFRC 
           SC =TSFSC
           A = TSFA
           B = TSFB 
           RM(KTEF) = TSFSC
           TF_KSI(KTEF) = TSF_KSI(KE1)

           TF_C1 = CC1
           TF_C2 = CC2
           TF_C3 = CC3
           TF_C4 = CC4
           TF_C5 = CC5
           TF_a  = ATF
           TF_alpha = TFMalpha
           TF_beta  = TFMbeta
        ELSE
           XMass(1) = MASS(KE1)
           XMass(2) = MASS(KE2)
           TL1 = (TSF_L1(KE1)+TSF_L1(KE2))/2.0d0
           TM1 = (TSF_M1(KE1)+TSF_M1(KE2))/2.0d0
           RC =SQRT(TSF_RC(KE1)*TSF_RC(KE2)) 
           SC =SQRT(TSF_SC(KE1)*TSF_SC(KE2)) 
           A = SQRT(TSF_A(KE1)*TSF_A(KE2))
           B = SQRT(TSF_B(KE1)*TSF_B(KE2))
           TF_KSI(KTEF) = TSF_KSI(3)
           RM(KTEF) = SQRT(TSF_SC(KE1)*TSF_SC(KE2))
        ENDIF

        IF(KTEF.EQ.1) alat = 5.43947d0! for 273K Si P = 0GPa

!@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
        DX=RM(KTEF)/NT
!        IF(KEYBS.EQ.8.AND.NTYPE.EQ.2) DX=rcc/NT ! In order to mix SW and EAM waterat the same range
!@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@

        UT(KTEF,1:NT) = 0.0d0
        FT(KTEF,1:NT) = 0.0d0
        FFR(KTEF,1:NT)= 0.0d0
        DFR(KTEF,1:NT)= 0.0d0
        FA(KTEF,1:NT) = 0.0d0
        DFA(KTEF,1:NT)= 0.0d0
        FC(KTEF,1:NT) = 0.0d0
        DFC(KTEF,1:NT)= 0.0d0
        DFCDFA(KTEF,1:NT) = 0.0d0
        DFCDFR(KTEF,1:NT) = 0.0d0
        
!        IF(mypid.eq.0) OPEN (UNIT = 444,FILE='TF-'//Element(KE1)//'-'//Element(KE2)//'.pot')
        
        XT=0.0d+00  
        
        DO I=1,NT
           XT=XT+DX 
           
           IF(XT.LE.SC) Then 
              
              FFR(KTEF,I) = A * exp(-TL1*XT)
              DFR(KTEF,I) = -TL1 * FFR(KTEF,I)
              
              FA(KTEF,I) = B * exp(-TM1*XT)
              DFA(KTEF,I) = -TM1 * FA(KTEF,I)
              
              ANG = PI*(XT-RC)/(SC-RC)
              
              IF(XT.LE.RC) Then
                 FC(KTEF,I)=1.0
                 DFC(KTEF,I)=0.0
              ENDIF
              
              IF(XT.GT.RC) Then
                 FC(KTEF,I)=0.5+0.5625*COS(PI*(XT-RC)/(SC-RC))-0.0625*COS(3*PI*(XT-RC)/(SC-RC))

                 DFC(KTEF,I) =-(9.0d0*PI/(16.0*(SC-RC))*SIN(PI*(XT-RC)/(SC-RC)) - &
                      3.0d0*PI/(16.0*(SC-RC))*SIN(3.0d0*PI*(XT-RC)/(SC-RC)))
              ENDIF
              
              DFCDFA(KTEF,I)=FC(KTEF,I)*DFA(KTEF,I)+FA(KTEF,I)*DFC(KTEF,I)
              DFCDFR(KTEF,I)=FC(KTEF,I)*DFR(KTEF,I)+FFR(KTEF,I)*DFC(KTEF,I)
              
              UT(KTEF,I) =  FC(KTEF,I)*(FFR(KTEF,I)-FA(KTEF,I))
              FT(KTEF,I) = DFCDFR(KTEF,I) - DFCDFA(KTEF,I)
        
!              Uncomment this line if want to plot the potential
!              IF(mypid.eq.0) WRITE (444,*) XT,UT(KTEF,I),FT(KTEF,I)

!             Transfer to program units
              UT(KTEF,I) = UT(KTEF,I)/ENUNIT
              FT(KTEF,I) = FT(KTEF,I)/ENUNIT
              
           ENDIF
           
        END DO

!        Uncomment this line if want to plot the potential
!        IF(mypid.eq.0) CLOSE (UNIT = 444)

        RETURN
      END SUBROUTINE EF1_TFM






